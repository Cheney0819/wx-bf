<Window
    x:Class="DesktopPet.Wpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Desktop Pet"
    Width="240"
    Height="258"
    WindowStyle="None"
    ResizeMode="NoResize"
    AllowsTransparency="True"
    Background="Transparent"
    ShowInTaskbar="False"
    Topmost="True">
    <Grid>
        <Canvas>
            <Border
                x:Name="SpeechBubble"
                Canvas.Left="38"
                Canvas.Top="8"
                MinWidth="128"
                MaxWidth="164"
                Padding="10,8"
                CornerRadius="16"
                Background="#FFF0F6">
                <TextBlock
                    x:Name="SpeechText"
                    Text="妈妈，我来陪你啦。"
                    Foreground="#8D2D59"
                    FontSize="12"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </Border>

            <Border
                x:Name="EmotionBadge"
                Canvas.Left="182"
                Canvas.Top="48"
                MinWidth="28"
                Height="24"
                Padding="6,0"
                CornerRadius="12"
                Background="#FFFFFFFF">
                <TextBlock
                    x:Name="EmotionText"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    FontSize="13"
                    FontWeight="Bold"
                    Foreground="#FF5E98"
                    Text="♡" />
            </Border>

            <Polygon
                Canvas.Left="112"
                Canvas.Top="58"
                Points="0,0 12,0 6,8"
                Fill="#FFF0F6" />

            <Image
                x:Name="PetImage"
                Canvas.Left="42"
                Canvas.Top="68"
                Width="156"
                Height="156"
                Stretch="Uniform"
                SnapsToDevicePixels="True"
                RenderOptions.BitmapScalingMode="NearestNeighbor" />
        </Canvas>
    </Grid>
</Window>
