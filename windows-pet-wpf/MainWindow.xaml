<Window
    x:Class="DesktopPet.Wpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Desktop Pet"
    Width="280"
    Height="300"
    WindowStyle="None"
    ResizeMode="NoResize"
    AllowsTransparency="True"
    Background="Transparent"
    ShowInTaskbar="False"
    Topmost="True">
    <Grid>
        <Canvas>
            <Border
                x:Name="SpeechBubble"
                Canvas.Left="50"
                Canvas.Top="8"
                MinWidth="144"
                MaxWidth="188"
                Padding="12,9"
                CornerRadius="18"
                Background="#FFF0F6">
                <TextBlock
                    x:Name="SpeechText"
                    Text="妈妈，我来陪你啦。"
                    Foreground="#8D2D59"
                    FontSize="13"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </Border>

            <Border
                x:Name="EmotionBadge"
                Canvas.Left="214"
                Canvas.Top="56"
                MinWidth="32"
                Height="28"
                Padding="7,0"
                CornerRadius="15"
                Background="#FFFFFFFF">
                <TextBlock
                    x:Name="EmotionText"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="#FF5E98"
                    Text="♡" />
            </Border>

            <Polygon
                Canvas.Left="132"
                Canvas.Top="64"
                Points="0,0 14,0 7,9"
                Fill="#FFF0F6" />

            <Image
                x:Name="PetImage"
                Canvas.Left="46"
                Canvas.Top="78"
                Width="188"
                Height="188"
                Stretch="Uniform"
                SnapsToDevicePixels="True"
                RenderOptions.BitmapScalingMode="NearestNeighbor" />
        </Canvas>
    </Grid>
</Window>
